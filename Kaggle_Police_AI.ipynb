        "!sudo apt-get install -y zstd > /dev/null 2>&1\n",
        "!curl -fsSL https://ollama.com/install.sh | sh\n",
        "import numpy as np\n",
        "import torch\n",
        "print(f\"✅ NumPy: {np.__version__} | ✅ CUDA: {torch.cuda.is_available()}\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": { "trusted": true },
      "source": [
        "import os, time, subprocess\n",
        "subprocess.Popen([\"ollama\", \"serve\"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)\n",
        "time.sleep(5)\n",
        "print(\"📥 Downloading Gemma2 9B...\")\n",
        "!ollama pull gemma2:9b\n",
        "lines = [\n",
        "    \"FROM gemma2:9b\",\n",
        "    \"PARAMETER temperature 0.05\",\n",
        "    \"PARAMETER num_ctx 32768\",\n",
        "    'SYSTEM \"\"\"You are the Sri Lanka Police AI Architect. Provide factual translations into JSON format.\"\"\"'\n",
        "]\n",
        "with open(\"Modelfile\", \"w\") as f: f.write(\"\\n\".join(lines))\n",
        "!ollama create police-ai-master -f Modelfile\n",
        "print(\"✅ AI Model Ready!\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": { "trusted": true },
      "source": [
        "NGROK_AUTH_TOKEN = \"3C0C7gFkX4IQuTy2cMMPHYznbNh_4CZ5YG6ekExX6sBKNfhpv\"\n",
        "print(f\"✅ Token set: {NGROK_AUTH_TOKEN[:8]}...\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": { "trusted": true },
      "source": [
        "import torch, time\n",
        "print(\"🧠 Loading Surya OCR...\")\n",
        "try:\n",
        "    from surya.foundation import FoundationPredictor\n",
        "    from surya.recognition import RecognitionPredictor\n",
        "    from surya.detection import DetectionPredictor\n",
        "    fp = FoundationPredictor()\n",
        "    rp = RecognitionPredictor(fp)\n",
        "    dp = DetectionPredictor()\n",
        "    SURYA_OK = True\n",
        "    print(\"✅ Surya OCR Loaded\")\n",
        "except Exception as e:\n",
        "    print(f\"❌ Surya failed: {e}\")\n",
        "    SURYA_OK = False"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": { "trusted": true },
      "source": [
        "from flask import Flask, request, jsonify, Response\n",
        "from PIL import Image\n",
        "import io, requests, threading\n",
        "app = Flask(__name__)\n",
        "@app.route(\"/gpu-ocr\", methods=[\"POST\"])\n",
        "def ocr():\n",
        "    img = Image.open(io.BytesIO(request.files[\"file\"].read())).convert(\"RGB\")\n",
        "    preds = rp([img], [None], dp)\n",
        "    txt = \"\\n\".join([l.text for l in preds[0].text_lines])\n",
        "    return jsonify({\"success\": True, \"text\": txt})\n",
        "@app.route(\"/api/generate\", methods=[\"POST\"])\n",
        "def gen():\n",
        "    d = request.get_json()\n",
        "    r = requests.post(\"http://localhost:11434/api/generate\", json=d, stream=d.get(\"stream\", False))\n",
        "    if d.get(\"stream\", False): return Response(r.iter_content(1024), content_type=r.headers['Content-Type'])\n",
        "    return r.json(), r.status_code\n",
        "threading.Thread(target=lambda: app.run(host=\"0.0.0.0\", port=5050), daemon=True).start()\n",
        "print(\"✅ API Server Ready on port 5050\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": { "trusted": true },
      "source": [
        "from pyngrok import ngrok\n",
        "import time\n",
        "ngrok.set_auth_token(NGROK_AUTH_TOKEN)\n",
        "for t in ngrok.get_tunnels(): ngrok.disconnect(t.public_url)\n",
        "url = ngrok.connect(5050).public_url\n",
        "print(f\"\\n🔥 PUBLIC URL: {url}\")\n",
        "while True: time.sleep(60)"
      ]
    }
