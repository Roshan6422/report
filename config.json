{
  "system": {
    "version": "v2.2.0",
    "name": "Police Report Processing Engine (Master Setup)",
    "organization": "Sri Lanka Police - IG's Command & Information Division"
  },
  "processing": {
    "default_mode": "regex",
    "enable_ai": true,
    "confidence_threshold": 0.6,
    "quality_gate_enabled": true,
    "cache_enabled": true,
    "cache_ttl_hours": 24
  },
  "ai_engines": {
    "default": "ollama",
    "fastapi": {
      "enabled": true,
      "provider": "github",
      "model": "gpt-4o-mini",
      "timeout": 120
    },
    "ollama": {
      "enabled": true,
      "local_model": "sri-lanka-police-ai:latest",
      "kaggle_model": "police-ai-master:latest",
      "base_url": "http://localhost:11434/api/generate",
      "kaggle_url": "https://nestable-mireya-uncarbonized.ngrok-free.dev/api/generate",
      "prefer_kaggle": true,
      "timeout": 180
    }
  },
  "report_settings": {
    "logo_path": "police_logo.png",
    "confidential_header": true,
    "include_signature_block": true,
    "include_distribution_list": true,
    "page_size": "A4",
    "font_family": "Times New Roman",
    "font_size": "12pt"
  },
  "output": {
    "base_directory": "uploads/sinhala",
    "html_enabled": true,
    "pdf_enabled": true,
    "json_enabled": false,
    "filename_format": "{basename}_{report_type}_Report"
  },
  "batch_processing": {
    "enabled": true,
    "max_concurrent": 1,
    "retry_on_failure": true,
    "max_retries": 2,
    "log_directory": "tmp/batch_logs"
  },
  "web_interface": {
    "host": "0.0.0.0",
    "port": 3000,
    "debug": false,
    "upload_folder": "uploads",
    "max_file_size_mb": 50,
    "allowed_extensions": [
      ".pdf",
      ".txt"
    ]
  },
  "analytics": {
    "generate_case_table": true,
    "generate_summary_matrix": true,
    "track_statistics": true,
    "save_processing_logs": true
  },
  "validation": {
    "require_station_name": true,
    "require_hierarchy": false,
    "require_reference_code": false,
    "min_body_length": 20,
    "validate_dates": true,
    "validate_money_values": true
  },
  "sections": {
    "general": [
      "01. SERIOUS CRIMES COMMITTED",
      "02. RAPE, SEXUAL ABUSE & CHILD ABUSE",
      "03. FATAL ACCIDENTS",
      "04. POLICE OFFICERS/VEHICLES INVOLVED IN ROAD ACCIDENTS AND DAMAGES TO SRI LANKA POLICE PROPERTY",
      "05. FINDING OF DEAD BODIES UNDER SUSPICIOUS CIRCUMSTANCES",
      "06. POLICE OFFICERS CHARGED IN COURTS / COMPLAINTS AGAINST POLICE",
      "07. SERIOUS INJURY / ILLNESSES / DEATHS OF POLICE OFFICERS",
      "08. DETECTION OF NARCOTIC AND ILLEGAL LIQUOR",
      "09. ARREST OF TRI-FORCES MEMBERS",
      "10. OTHER MATTERS"
    ]
  },
  "provinces": [
    "WESTERN PROVINCE",
    "SABARAGAMUWA PROVINCE",
    "SOUTHERN PROVINCE",
    "UVA PROVINCE",
    "CENTRAL PROVINCE",
    "NORTH WESTERN PROVINCE",
    "NORTH CENTRAL PROVINCE",
    "EASTERN PROVINCE",
    "NORTHERN PROVINCE"
  ]
}